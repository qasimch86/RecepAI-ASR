{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recepai.local/schemas/VoiceIntent.v1.schema.json",
  "title": "VoiceIntent v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "slots"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "search_product",
        "select_product",
        "add_to_cart",
        "view_cart",
        "remove_from_cart",
        "set_quantity",
        "checkout",
        "clarify",
        "cancel"
      ]
    },
    "slots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "storeId": {
          "type": "integer",
          "minimum": 1
        },
        "query": {
          "type": "string",
          "minLength": 1
        },
        "productId": {
          "type": "string",
          "minLength": 1
        },
        "productName": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        },
        "cartItemId": {
          "type": "string",
          "minLength": 1
        },
        "confirmation": {
          "type": "boolean"
        },
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    }
  }
}
